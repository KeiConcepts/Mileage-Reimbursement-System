# Next.js dev server
PORT=3000
HOST=127.0.0.1

# Google Maps Platform
# Server key needs Routes API enabled.
GOOGLE_MAPS_API_KEY=
# Browser key is optional. If set, address inputs get Google Places autocomplete.
GOOGLE_MAPS_BROWSER_KEY=

# Monday test board. Leave blank until you create the separate test board.
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=
MONDAY_API_VERSION=2026-04
MONDAY_STATUS_LABEL=Submitted

# Optional Monday column ids. The app skips any blank mappings.
MONDAY_COL_EMPLOYEE_EMAIL=
MONDAY_COL_APPROVER_EMAIL=
MONDAY_COL_PAYROLL_EMAIL=
MONDAY_COL_POSITION=
MONDAY_COL_PRIMARY_WORKPLACE=
MONDAY_COL_SUBMISSION_DATE=
MONDAY_COL_PERIOD_START=
MONDAY_COL_PERIOD_END=
MONDAY_COL_TRIP_SUMMARY=
MONDAY_COL_ACTUAL_MILES=
MONDAY_COL_COMMUTE_DEDUCTION=
MONDAY_COL_REIMBURSABLE_MILES=
MONDAY_COL_TRIP_DAYS=
MONDAY_COL_REIMBURSEMENT_AMOUNT=
MONDAY_COL_NOTES=
MONDAY_COL_STATUS=

# Workplace names shown in the primary workplace menu.
WORKPLACE_NAMES=KEI HQ,VOX FV,VOX SCP,SUP BP,SUP IR
# Optional override for quick-address dropdowns. Must be JSON.
# LOCATION_PRESETS_JSON=[{"name":"KEI HQ","address":"17011 Beach Blvd Unit 676, Huntington Beach, CA 92647"}]
